# Backend Environment Variables

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/vasavi_traders

# Server port
PORT=4000

# Frontend origins allowed to call the API
FRONTEND_URL=http://localhost:5173,https://your-frontend.vercel.app

# Secret key for signing JWT access tokens
JWT_SECRET=replace_with_a_long_random_secret

# Secret key for signing JWT refresh tokens
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret

# Google OAuth client IDs allowed by the backend
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_IDS=your-google-client-id.apps.googleusercontent.com

# Optional bootstrap admin account for first production deploy
BOOTSTRAP_ADMIN_NAME=Vasavi Admin
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# Node environment
NODE_ENV=development
