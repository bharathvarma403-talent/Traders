# Backend Environment Variables

# Secret key for signing JWT access tokens (use a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_here

# Secret key for signing JWT refresh tokens (different from JWT_SECRET)
JWT_REFRESH_SECRET=your_refresh_secret_key_here

# Google OAuth 2.0 Client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:5173,https://your-frontend.vercel.app

# Node environment: development | production
NODE_ENV=development

# SQLite database path (Prisma reads this automatically)
DATABASE_URL=file:./dev.db

# Server port (default: 4000)
PORT=4000
